# Slack app (Socket Mode)
SLACK_BOT_TOKEN='xoxb-your-bot-token'
SLACK_APP_TOKEN=xapp-your-app-level-token
SLACK_SIGNING_SECRET=your-signing-secret

# Optional: permalink domain for handoff blocks, e.g. yourworkspace.slack.com
SLACK_WORKSPACE_DOMAIN=

# Optional: post copy of handoff to this channel (C…)
ESCALATION_CHANNEL_ID=

# Ollama (local LLM)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:latest
# Optional: separate model for test judge (defaults to OLLAMA_MODEL)
# JUDGE_MODEL=llama3.2:latest

# NLU routing
CONFIDENCE_THRESHOLD=0.65
INTEGRATION_PROVIDER=stub

# Session guardrails
MAX_SESSION_TURNS=12
MAX_CLARIFY_ROUNDS=3

# Integration reliability
INTEGRATION_MAX_RETRIES=2
INTEGRATION_RETRY_BASE_MS=250
INTEGRATION_CIRCUIT_FAILURES=3
INTEGRATION_CIRCUIT_OPEN_MS=15000

# Optional API server (for non-Slack integrations)
API_SERVER_ENABLED=0
API_SERVER_PORT=8787
# API_SERVER_AUTH_TOKEN=replace_me

# Pilot rollout / feature flags
PILOT_MODE=off
FEATURE_AVAILABILITY=1
FEATURE_BOOKING=1
FEATURE_APPOINTMENT_CHANGE=1
FEATURE_ELIGIBILITY=1
FEATURE_PATIENT_DRAFT=1
FEATURE_CARE_NAVIGATION=1
FEATURE_INTAKE_SUBMIT=1
FEATURE_TASK_ROUTING=1

# Logging safety
REDACT_LOGS=1

# SQLite directory (created automatically)
DATA_DIR=./data

# Optional: clinic rules JSON for primary + alternate slot hints (default: ./config/clinic-hours.sample.json)
# CLINIC_HOURS_PATH=./config/clinic-hours.sample.json

# Optional: policy redline regexes for forced handoff + PHI audit patterns (default: ./config/policy-redlines.json)
# POLICY_REDLINES_PATH=./config/policy-redlines.json

# Optional: Slack voice/audio clips. NLU still uses Ollama. Slack app needs bot scope: files:read
#
# Local (no API cost): venv python with `pip install faster-whisper`, ffmpeg on PATH
# FASTER_WHISPER_PYTHON=/path/to/venv/bin/python3
# FASTER_WHISPER_SCRIPT=   # default: <cwd>/scripts/transcribe_faster_whisper.py
# FASTER_WHISPER_MODEL=small
# FASTER_WHISPER_TIMEOUT_MS=180000
#
# Cloud (OpenAI-compatible) — used if local fails or FASTER_WHISPER_PYTHON unset
# WHISPER_API_KEY=sk-...
# OPENAI_API_KEY=sk-...
# WHISPER_API_URL=https://api.openai.com/v1/audio/transcriptions
# WHISPER_MODEL=whisper-1
