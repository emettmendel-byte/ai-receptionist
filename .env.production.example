# Greens Health AI Receptionist — hosted production baseline
# Copy into your platform secret manager (do not commit real secrets).

# Slack (Socket Mode)
SLACK_BOT_TOKEN=xoxb-REPLACE_ME
SLACK_APP_TOKEN=xapp-REPLACE_ME
SLACK_SIGNING_SECRET=REPLACE_ME
SLACK_WORKSPACE_DOMAIN=yourworkspace.slack.com
ESCALATION_CHANNEL_ID=

# NLU / LLM
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:latest
# Optional Gemini primary path (recommended for hosted): if key is set, Gemini is used first and Ollama is fallback.
# GEMINI_API_KEY=REPLACE_ME
# GEMINI_MODEL=gemini-1.5-flash
# GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
CONFIDENCE_THRESHOLD=0.65

# Integration provider + rollout controls
INTEGRATION_PROVIDER=stub
PILOT_MODE=shadow
FEATURE_AVAILABILITY=1
FEATURE_BOOKING=1
FEATURE_APPOINTMENT_CHANGE=1
FEATURE_ELIGIBILITY=1
FEATURE_PATIENT_DRAFT=1
FEATURE_CARE_NAVIGATION=1
FEATURE_INTAKE_SUBMIT=1
FEATURE_TASK_ROUTING=1

# Reliability
INTEGRATION_MAX_RETRIES=2
INTEGRATION_RETRY_BASE_MS=250
INTEGRATION_CIRCUIT_FAILURES=3
INTEGRATION_CIRCUIT_OPEN_MS=15000

# API mode (enable for health checks + system integrations)
API_SERVER_ENABLED=1
API_SERVER_PORT=8787
API_SERVER_AUTH_TOKEN=REPLACE_ME_STRONG_TOKEN

# Logging / governance
REDACT_LOGS=1
MAX_SESSION_TURNS=12
MAX_CLARIFY_ROUNDS=3

# Storage
# For Render persistent disk example:
# DATA_DIR=/var/data
DATA_DIR=./data

# Optional config files
# CLINIC_HOURS_PATH=./config/clinic-hours.sample.json
# POLICY_REDLINES_PATH=./config/policy-redlines.json
